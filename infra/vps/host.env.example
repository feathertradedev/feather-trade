# Non-secret Docker Compose inputs. Copy to an operator-owned path outside the
# repository and pass it with `docker compose --env-file`.
COMPOSE_PROJECT_NAME=feather-mainnet

# Build packages/analytics/Dockerfile in trusted CI, push it, and split the
# immutable registry reference into these fields. Compose always reconstructs
# an @sha256 reference, so a mutable tag cannot be selected accidentally.
FEATHER_ANALYTICS_IMAGE_REPOSITORY=ghcr.io/feathertradedev/feather-analytics
FEATHER_ANALYTICS_IMAGE_DIGEST=REPLACE_WITH_64_HEX_CHARACTERS

# Container availability ceilings. Measure production usage before lowering
# these defaults; an OOM is an observable analytics outage, not silent data loss.
FEATHER_ANALYTICS_CPUS=2.0
FEATHER_ANALYTICS_MEMORY_LIMIT=2g
FEATHER_ANALYTICS_MAX_STREAMS_PER_IP=20
FEATHER_ANALYTICS_GRAPHQL_REQUESTS_PER_MINUTE=120
FEATHER_ANALYTICS_GRAPHQL_RATE_LIMIT_CLIENTS=4096
FEATHER_ANALYTICS_POSITION_SNAPSHOT_TIMEOUT_MS=5000
FEATHER_ANALYTICS_DATABASE_KEEPALIVE_INITIAL_DELAY_MS=10000
FEATHER_ANALYTICS_DATABASE_HEALTH_INTERVAL_MS=5000
FEATHER_ANALYTICS_DATABASE_FAILURE_GRACE_MS=120000
FEATHER_CADDY_CPUS=1.0
FEATHER_CADDY_MEMORY_LIMIT=512m

FEATHER_APP_DOMAIN=app.feather.markets
FEATHER_DOCS_DOMAIN=feather.markets

# Keep this exact and release-reviewed. Include 'self' plus only the RPC,
# indexer, wallet, and other browser endpoints embedded in the sealed build.
FEATHER_APP_CONNECT_SRC="'self' https://rpc.mainnet.chain.robinhood.com https://REPLACE_INDEXER_ORIGIN"

# Absolute host paths. analytics.env must be chmod 0600. Releases contains
# immutable release directories and a relative `current` symlink.
FEATHER_ANALYTICS_ENV_FILE=/etc/feather/analytics/analytics.env
FEATHER_ANALYTICS_CONFIG_DIR=/etc/feather/analytics/config
FEATHER_ANALYTICS_ADAPTERS_DIR=/etc/feather/analytics/adapters
# This must equal the promotion environment's WEB_VPS_RELEASE_ROOT.
FEATHER_RELEASES_DIR=/srv/feather/web/mainnet
