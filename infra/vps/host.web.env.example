# Non-secret inputs for the Sepolia web-only stage. Copy this file to an
# operator-owned path and pass it to compose.web.yml with `--env-file`.
COMPOSE_PROJECT_NAME=feather-sepolia-web

FEATHER_CADDY_CPUS=1.0
FEATHER_CADDY_MEMORY_LIMIT=512m

# These must remain exact hostnames: Caddy obtains and renews certificates for
# both names and does not serve a catch-all virtual host.
FEATHER_APP_DOMAIN=app.example.invalid
FEATHER_DOCS_DOMAIN=docs.example.invalid

# This is the complete non-Reown browser connection allowlist for the sealed
# Sepolia build. Reown's reviewed origins are fixed in Caddyfile.web. Never use
# broad `https:`, `wss:`, or `*` sources here.
FEATHER_APP_CONNECT_SRC="'self' https://ethereum-sepolia-rpc.publicnode.com"

# This must equal the protected Sepolia promotion environment's
# WEB_VPS_RELEASE_ROOT. Releases are immutable; only the relative `current`
# pointer changes atomically during promotion.
FEATHER_RELEASES_DIR=/srv/feather/web/sepolia
