# Secret-bearing runtime configuration. Store the real file outside the repo,
# owned by root with mode 0600. Do not pass it through Docker build arguments.
ANALYTICS_DATABASE_URL=postgresql://feather:REPLACE_PASSWORD@REPLACE_MANAGED_POSTGRES_HOST:5432/feather?sslmode=verify-full
ANALYTICS_DATABASE_SCHEMA=feather_analytics_mainnet

ANALYTICS_ENVIRONMENT=mainnet
ANALYTICS_DEPLOYMENT_IDENTITY=mainnet:REPLACE_WITH_APPROVED_ADAPTER_RELEASE_ID
ANALYTICS_RUNTIME_CUSTODY=/run/feather/config/runtime-custody.json
ANALYTICS_RUNTIME_CUSTODY_SHA256=REPLACE_WITH_64_HEX_CHARACTERS_FROM_CUSTODY_BUILD
ANALYTICS_PRICE_POLICIES=/run/feather/config/price-policies.json
ANALYTICS_PRICE_VERIFIER_MODULE=/run/feather/adapters/chainlink-verifier.mjs
ANALYTICS_BLOCK_SOURCE_MODULE=/run/feather/adapters/canonical-block-source.mjs
ANALYTICS_POSITION_SNAPSHOT_MODULE=/run/feather/adapters/position-snapshot-provider.mjs
ANALYTICS_MANIFEST_PATH=/run/feather/config/deployment.json
# This may contain a provider credential. Keep it only in this root-owned file.
ANALYTICS_RPC_URL=https://REPLACE_WITH_PROVIDER_RPC

# Compose overrides CORS with the exact HTTPS app origin and enables trusted
# proxy parsing only behind Caddy's sanitized X-Forwarded-For. Do not publish
# the analytics container port directly.
ANALYTICS_CORS_ORIGINS=
ANALYTICS_MAX_HEAD_LAG_SECONDS=120
ANALYTICS_MAX_POSITION_SNAPSHOT_AGE_SECONDS=300
ANALYTICS_CHAINLINK_SAMPLE_BLOCK_INTERVAL=5
ANALYTICS_BACKFILL_MAX_PAGES=10000
ANALYTICS_READINESS_TIMEOUT_MS=2000
ANALYTICS_POSITION_SNAPSHOT_TIMEOUT_MS=5000
ANALYTICS_DATABASE_KEEPALIVE_INITIAL_DELAY_MS=10000
ANALYTICS_DATABASE_HEALTH_INTERVAL_MS=5000
ANALYTICS_DATABASE_FAILURE_GRACE_MS=120000
ANALYTICS_SHUTDOWN_TIMEOUT_MS=10000

# Optional. Leave unset to disable POST /internal/blocks. Even when enabled,
# Caddy never exposes this path publicly.
# ANALYTICS_INGEST_TOKEN=REPLACE_WITH_RANDOM_SECRET
