{
  "name": "@robinhood-lb/subgraph",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate": "node ../../scripts/indexer/generate-subgraph.cjs",
    "generate:local": "node ../../scripts/indexer/generate-subgraph-local.cjs",
    "generate:robinhood": "node ../../scripts/indexer/generate-subgraph-robinhood.cjs",
    "codegen": "pnpm generate:local && graph codegen subgraph.yaml",
    "codegen:rendered": "graph codegen subgraph.yaml",
    "build": "pnpm codegen && graph build subgraph.yaml",
    "build:rendered": "graph build subgraph.yaml",
    "test:mappings": "pnpm codegen && graph test --version 0.6.0",
    "deploy:local": "pnpm generate:local && graph codegen subgraph.yaml && (graph create --node \"${GRAPH_NODE_ADMIN_URL:-http://localhost:8020/}\" robinhood-lb/localnet || true) && graph deploy --node \"${GRAPH_NODE_ADMIN_URL:-http://localhost:8020/}\" --ipfs \"${GRAPH_NODE_IPFS_URL:-http://localhost:5001}\" --version-label v0.1.0 robinhood-lb/localnet subgraph.yaml"
  },
  "dependencies": {
    "@graphprotocol/graph-cli": "0.98.1",
    "@graphprotocol/graph-ts": "0.38.2"
  },
  "devDependencies": {
    "assemblyscript": "0.19.23",
    "matchstick-as": "0.6.0"
  }
}
