{
  "name": "@robinhood-lb/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "pnpm docs:validate && tsc -b && vite build && pnpm docs:prerender",
    "docs:prerender": "node scripts/prerender-docs.mjs",
    "docs:generate": "node scripts/generate-doc-index.mjs",
    "docs:generate:check": "node scripts/generate-doc-index.mjs --check",
    "docs:test": "node scripts/test-docs-build.mjs",
    "docs:validate": "pnpm docs:generate:check && node scripts/validate-docs.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "test:e2e": "playwright test",
    "test:analytics-data": "node scripts/test-analytics-data.mjs",
    "test:full-exit-batching": "node scripts/test-full-exit-batching.mjs",
    "test:pagination": "node scripts/test-graphql-pagination.mjs",
    "test:pair-attestation": "node scripts/test-pair-attestation.mjs",
    "test:liquidity-amount-suggestion": "node scripts/test-liquidity-amount-suggestion.mjs",
    "test:liquidity-review": "node scripts/test-liquidity-review.mjs",
    "test:full-exit-policy": "node scripts/test-full-exit-policy.mjs",
    "test:lb-operator-approval": "node scripts/test-lb-operator-approval.mjs",
    "test:pool-selection": "node scripts/test-pool-selection.mjs",
    "test:pool-discovery": "node scripts/test-pool-discovery.mjs && node scripts/test-pool-discovery-model.mjs",
    "test:pool-economics": "node scripts/test-pool-economics.mjs",
    "test:pool-workspace-route": "node scripts/test-pool-workspace-route.mjs",
    "test:positions": "node scripts/test-position-burn-plan.mjs",
    "test:safety": "node scripts/test-transaction-safety.mjs",
    "test:transaction-journal": "node scripts/test-transaction-journal.mjs",
    "test:token-safety": "node scripts/test-token-safety.mjs",
    "typecheck": "tsc -b --pretty false"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/schibsted-grotesk": "^5.2.8",
    "@mdx-js/react": "^3.1.1",
    "@reown/appkit": "1.8.22",
    "@reown/appkit-adapter-wagmi": "1.8.22",
    "@robinhood-lb/sdk": "workspace:*",
    "@tanstack/react-query": "^5.101.2",
    "lightweight-charts": "^5.2.0",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "viem": "^2.54.6",
    "wagmi": "^3.7.1"
  },
  "devDependencies": {
    "@mdx-js/mdx": "^3.1.1",
    "@mdx-js/rollup": "^3.1.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "gray-matter": "^4.0.3",
    "rehype-slug": "^6.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-mdx-frontmatter": "^5.2.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3"
  }
}
