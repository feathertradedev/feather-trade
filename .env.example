# Robinhood Chain RPC endpoints used by root foundry.toml.
ROBINHOOD_RPC_URL="https://rpc.mainnet.chain.robinhood.com"
ROBINHOOD_TESTNET_RPC_URL="https://rpc.testnet.chain.robinhood.com"
ROBINHOOD_ENV="testnet"

# Deployment scripts must use a local/private value. Never commit a real key.
DEPLOYER_PRIVATE_KEY="0xffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffff"
ROBINHOOD_DEPLOYER_PRIVATE_KEY=""
ROBINHOOD_MANIFEST_PATH=""
ROBINHOOD_WNATIVE_ADDRESS=""
# Mainnet defaults to canonical USDG when unset. Leave zero/empty for testnet.
ROBINHOOD_QUOTE_ASSET_0=""
ROBINHOOD_QUOTE_ASSET_1=""
ROBINHOOD_QUOTE_ASSET_2=""
ROBINHOOD_QUOTE_ASSET_3=""
ROBINHOOD_PRODUCTION_OWNER=""
ROBINHOOD_FEE_RECIPIENT=""
ROBINHOOD_OWNERSHIP_RPC_URL=""
ROBINHOOD_RPC_READINESS_RPC_URL=""
ROBINHOOD_ARCHIVE_RPC_URL=""
ROBINHOOD_MAINNET_ARCHIVE_RPC_URL=""
ROBINHOOD_TESTNET_ARCHIVE_RPC_URL=""
ROBINHOOD_FALLBACK_RPC_URL=""
ROBINHOOD_MAINNET_FALLBACK_RPC_URL=""
ROBINHOOD_TESTNET_FALLBACK_RPC_URL=""
ROBINHOOD_RPC_CHECK_PAIR=""
ROBINHOOD_RPC_CHECK_PAIR_BLOCK=""

# Local Anvil deployment defaults. The key below is Anvil account #0.
LOCALNET_RPC_URL="http://127.0.0.1:8545"
LOCALNET_CHAIN_ID="31337"
LOCALNET_PRIVATE_KEY="0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80"
LOCALNET_MANIFEST_PATH=""

# Local/testnet-only WETH/USDC activity service. Mainnet is always rejected.
MARKET_ACTIVITY_RPC_URL="http://127.0.0.1:8545"
MARKET_ACTIVITY_PRIVATE_KEY="0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80"
MARKET_ACTIVITY_MANIFEST_PATH="deployments/localnet/latest.json"
# Optional bounds and pacing overrides.
MARKET_ACTIVITY_INTERVAL_MS="10000"
# Optional deterministic seed. Omit for a fresh live pattern on every start.
MARKET_ACTIVITY_RANDOM_SEED=""
MARKET_ACTIVITY_HARD_RADIUS="8"
MARKET_ACTIVITY_TURNAROUND_RADIUS="6"
MARKET_ACTIVITY_WETH_AMOUNT="1.5"
MARKET_ACTIVITY_USDC_AMOUNT="3000"
MARKET_ACTIVITY_WETH_CAP="2.5"
MARKET_ACTIVITY_USDC_CAP="5000"
MARKET_ACTIVITY_WETH_BUDGET="5000"
MARKET_ACTIVITY_USDC_BUDGET="5000000"

# Optional public Feather destinations. Unset links are not rendered.
VITE_FEATHER_DOCS_URL=""
VITE_FEATHER_SECURITY_URL=""
VITE_FEATHER_X_URL=""
VITE_FEATHER_DISCORD_URL=""

# Reown AppKit project ID for the unified browser and mobile wallet chooser.
# Create a project at https://dashboard.reown.com and keep this value public-client only.
VITE_REOWN_PROJECT_ID=""

# Upstream compatibility and optional fork-test variables.
AVALANCHE_RPC_URL=""
FUJI_RPC_URL=""
SNOWTRACE_API_KEY=""
ARBISCAN_API_KEY=""
ARBITRUM_TESTNET_RPC_URL=""
