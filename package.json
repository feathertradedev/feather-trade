{
  "name": "feather-trade",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "devDependencies": {
    "wrangler": "4.110.0"
  },
  "scripts": {
    "contracts:build": "forge build",
    "contracts:test": "pnpm contracts:test:core",
    "contracts:test:core": "forge test --match-contract '^(LiquidityBinFactoryTest|LBPairInitialStateTest|LBPairSwapTest|LBPairLiquidityTest|LiquidityBinRouterTest|LiquidityBinRouterSwapTest)$'",
    "contracts:test:full": "forge test --gas-limit 4000000000 --no-match-path 'contracts/joe-v2/test/integration/*' --no-match-contract '^GetOracleLengthTest$'",
    "contracts:test:fork": "pnpm contracts:test:fork:router && pnpm contracts:test:fork:quoter && pnpm contracts:test:fork:priority",
    "contracts:test:fork:router": "node scripts/contracts/require-fork-rpc.cjs AVALANCHE_RPC_URL fork-router && forge test --match-path 'contracts/joe-v2/test/integration/LBRouter.t.sol'",
    "contracts:test:fork:quoter": "node scripts/contracts/require-fork-rpc.cjs AVALANCHE_RPC_URL fork-quoter && forge test --match-path 'contracts/joe-v2/test/integration/LBQuoter.t.sol'",
    "contracts:test:fork:priority": "node scripts/contracts/require-fork-rpc.cjs AVALANCHE_RPC_URL fork-priority && forge test --match-path 'contracts/joe-v2/test/integration/LBQuoterPriority.t.sol'",
    "contracts:test:exhaustive": "pnpm contracts:test:full && pnpm contracts:test:fork",
    "contracts:fmt": "forge fmt --check",
    "localnet:deploy": "bash scripts/localnet/deploy.sh",
    "localnet:up": "bash scripts/localnet/up.sh",
    "localnet:down": "bash scripts/localnet/down.sh",
    "robinhood:dry-run": "bash scripts/robinhood/dry-run.sh",
    "robinhood:deploy": "bash scripts/robinhood/deploy.sh",
    "robinhood:deploy:test": "node scripts/robinhood/test-deploy-wrapper.cjs",
    "robinhood:verify": "bash scripts/robinhood/verify.sh",
    "robinhood:verify:test": "node scripts/robinhood/test-verify-constructor-args.cjs",
    "robinhood:ownership:check": "node scripts/robinhood/check-ownership-handoff.cjs",
    "robinhood:ownership:test": "node scripts/robinhood/test-check-ownership-handoff.cjs",
    "robinhood:rpc:check": "node scripts/robinhood/check-rpc-readiness.cjs",
    "robinhood:rpc:test": "node scripts/robinhood/test-check-rpc-readiness.cjs",
    "robinhood:remove-liquidity:rehearse": "node scripts/robinhood/rehearse-remove-liquidity.cjs",
    "robinhood:remove-liquidity:test": "node scripts/robinhood/test-rehearse-remove-liquidity-batching.cjs",
    "launch:health": "node scripts/release/check-launch-health.cjs",
    "launch:health:test": "node scripts/release/test-check-launch-health.cjs",
    "observability:validate": "node scripts/release/validate-observability-evidence.cjs infra/monitoring/tabletop-evidence.template.json --allow-template",
    "observability:evidence:validate": "node scripts/release/validate-observability-evidence.cjs",
    "observability:test": "node scripts/release/test-validate-observability-evidence.cjs",
    "observability:redaction:test": "node scripts/web/test-redact-observability-output.cjs",
    "graph-node:validate": "node scripts/release/check-self-hosted-graph-node.cjs",
    "release:gates": "node scripts/release/check-wave-2-gates.cjs",
    "release:provenance": "node scripts/release/dependency-provenance-report.cjs",
    "release:provenance:report": "node scripts/release/dependency-provenance-report.cjs --full --output docs/provenance/dependency-license-report.md",
    "release:provenance:check": "node scripts/release/dependency-provenance-report.cjs --full --check docs/provenance/dependency-license-report.md",
    "release:static-analysis:triage": "node scripts/release/check-static-analysis-triage.cjs",
    "release:audit:validate": "node scripts/release/validate-audit-readiness.cjs --pr-integrity",
    "release:audit:strict": "node scripts/release/validate-audit-readiness.cjs",
    "release:audit:test": "node scripts/release/test-validate-audit-readiness.cjs",
    "release:audit:bundle": "node scripts/release/build-audit-bundle.cjs",
    "release:launch-records:validate": "node scripts/release/validate-launch-records.cjs --allow-template docs/wave-2/launch/final-go-no-go.template.json docs/wave-2/launch/rpc-provider-decision.template.json docs/wave-2/launch/admin-control-decision.template.json",
    "release:launch-records:test": "node scripts/release/test-validate-launch-records.cjs",
    "release:launch-records:strict": "node scripts/release/validate-launch-records.cjs --commit-mode candidate --candidate-commit \"$RELEASE_COMMIT\" \"$FINAL_GO_NO_GO_RECORD\" \"$RPC_PROVIDER_RECORD\" \"$ADMIN_CONTROL_RECORD\"",
    "release:web-promotion:test": "node scripts/release/test-web-promotion.cjs",
    "release:runbooks:validate": "node scripts/release/validate-operator-runbooks.cjs",
    "release:runbooks:test": "node scripts/release/test-validate-operator-runbooks.cjs",
    "release:testnet-evidence:materialize": "node scripts/release/materialize-testnet-evidence.cjs",
    "release:testnet-evidence:check": "node scripts/release/materialize-testnet-evidence.cjs --check && node scripts/release/validate-testnet-launch-packet.cjs",
    "release:testnet-evidence:test": "node scripts/release/test-validate-testnet-launch-packet.cjs",
    "manifests:validate": "node scripts/manifests/validate-manifests.cjs && node scripts/manifests/test-validate-manifests.cjs",
    "tokens:validate": "node scripts/tokens/validate-token-lists.cjs",
    "sdk:build": "pnpm --filter @robinhood-lb/sdk build",
    "sdk:test": "pnpm --filter @robinhood-lb/sdk test",
    "sdk:typecheck": "pnpm --filter @robinhood-lb/sdk typecheck",
    "sdk:example:localnet": "pnpm --filter @robinhood-lb/sdk example:localnet",
    "sdk:example:localnet:liquidity": "pnpm --filter @robinhood-lb/sdk example:localnet:liquidity",
    "sdk:example:localnet:swap": "pnpm --filter @robinhood-lb/sdk example:localnet:swap",
    "sdk:e2e:localnet:expected-revert": "pnpm --filter @robinhood-lb/sdk e2e:localnet:expected-revert",
    "analytics:build": "pnpm --filter @robinhood-lb/analytics build",
    "analytics:test": "pnpm --filter @robinhood-lb/analytics test",
    "analytics:typecheck": "pnpm --filter @robinhood-lb/analytics typecheck",
    "e2e:localnet": "node scripts/e2e/run-localnet-transactions.cjs",
    "web:test:e2e:localnet": "node scripts/e2e/run-browser-localnet.cjs",
    "web:dev": "pnpm --filter @robinhood-lb/web dev",
    "web:build": "pnpm --filter @robinhood-lb/web build",
    "web:preview": "pnpm --filter @robinhood-lb/web preview",
    "web:test:e2e": "pnpm --filter @robinhood-lb/web test:e2e",
    "web:test:pagination": "pnpm --filter @robinhood-lb/web test:pagination",
    "web:test:pool-selection": "pnpm --filter @robinhood-lb/web test:pool-selection",
    "web:test:positions": "pnpm --filter @robinhood-lb/web test:positions",
    "web:test:safety": "pnpm --filter @robinhood-lb/web test:safety",
    "web:typecheck": "pnpm --filter @robinhood-lb/web typecheck",
    "web:fixture:public": "node scripts/web/create-public-config-fixture.cjs",
    "web:test:public-config": "node scripts/web/test-public-config.cjs",
    "web:validate:public-config": "node scripts/web/validate-public-config.cjs",
    "web:check:public-artifact": "node scripts/web/check-public-artifact.cjs",
    "web:check:hosted-release": "node scripts/web/check-hosted-release.cjs",
    "web:test:hosted-release": "node scripts/web/test-check-hosted-release.cjs",
    "web:write:public-headers": "node scripts/web/write-public-headers.cjs",
    "web:build:public:testnet": "pnpm tokens:validate && pnpm web:validate:public-config -- --environment robinhoodTestnet --manifest \"$VITE_ROBINHOOD_TESTNET_MANIFEST_PATH\" && VITE_PUBLIC_RELEASE_ENV=robinhoodTestnet pnpm web:build && pnpm web:write:public-headers -- --manifest \"$VITE_ROBINHOOD_TESTNET_MANIFEST_PATH\" --dist apps/web/dist --analytics \"$VITE_ANALYTICS_ROBINHOOD_TESTNET_URL\"",
    "web:build:public:mainnet": "pnpm tokens:validate && pnpm web:validate:public-config -- --environment robinhood --manifest \"$VITE_ROBINHOOD_MANIFEST_PATH\" && VITE_PUBLIC_RELEASE_ENV=robinhood pnpm web:build && pnpm web:write:public-headers -- --manifest \"$VITE_ROBINHOOD_MANIFEST_PATH\" --dist apps/web/dist --analytics \"$VITE_ANALYTICS_ROBINHOOD_URL\"",
    "indexer:up": "docker compose -f indexer/subgraph/docker-compose.yml up -d",
    "indexer:down": "docker compose -f indexer/subgraph/docker-compose.yml down",
    "indexer:logs": "docker compose -f indexer/subgraph/docker-compose.yml logs -f graph-node",
    "indexer:generate": "node scripts/indexer/generate-subgraph.cjs",
    "indexer:generate:local": "node scripts/indexer/generate-subgraph-local.cjs",
    "indexer:generate:robinhood": "node scripts/indexer/generate-subgraph-robinhood.cjs",
    "indexer:codegen": "pnpm --filter @robinhood-lb/subgraph codegen",
    "indexer:codegen:rendered": "pnpm --filter @robinhood-lb/subgraph codegen:rendered",
    "indexer:build": "pnpm --filter @robinhood-lb/subgraph build",
    "indexer:build:rendered": "pnpm --filter @robinhood-lb/subgraph build:rendered",
    "indexer:build:robinhood:testnet": "pnpm indexer:generate:robinhood --manifest deployments/examples/robinhood-testnet.example.json && pnpm indexer:codegen:rendered && pnpm indexer:build:rendered",
    "indexer:build:robinhood:mainnet": "pnpm indexer:generate:robinhood --manifest deployments/examples/robinhood-mainnet.example.json && pnpm indexer:codegen:rendered && pnpm indexer:build:rendered",
    "indexer:e2e:graph-node": "bash scripts/indexer/run-graph-node-e2e.sh",
    "indexer:test:graph-node-assertions": "node scripts/indexer/test-assert-graph-node-mappings.cjs",
    "indexer:test:goldsky:robinhood": "node scripts/indexer/test-deploy-goldsky-robinhood.cjs",
    "indexer:test:pair-fees": "pnpm --filter @robinhood-lb/subgraph test:mappings",
    "indexer:test:smoke:robinhood": "node scripts/indexer/test-validate-smoke-robinhood.cjs && node scripts/indexer/test-smoke-robinhood-wrapper.cjs",
    "indexer:deploy:local": "pnpm --filter @robinhood-lb/subgraph deploy:local",
    "indexer:deploy:goldsky:robinhood": "bash scripts/indexer/deploy-goldsky-robinhood.sh",
    "indexer:smoke:local": "bash scripts/indexer/smoke-local.sh",
    "indexer:smoke:robinhood": "bash scripts/indexer/smoke-robinhood.sh",
    "build": "pnpm contracts:build && pnpm sdk:build && pnpm analytics:build && pnpm indexer:build && pnpm web:build",
    "test": "pnpm contracts:test"
  }
}
